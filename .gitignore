# Laravel environment and credentials
.env
.env.*
!.env.example
/auth.json

# PHP / JavaScript dependencies
/vendor/
/node_modules/

# Laravel runtime files
/public/hot
/public/storage
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*.php

# Local databases and database exports
/database/*.sqlite
/database/*.sqlite-*
/database/*.sql
/database/*.dump
/database/*.bak

# Private keys / certificates
*.pem
*.p12
*.pfx
*.key
id_rsa*
id_ed25519*

# Logs and local tooling
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.phpunit.result.cache
/.phpunit.cache/
/.idea/
/.vscode/
.DS_Store
Thumbs.db

